{
  "name": "@agent-infinite/desktop",
  "version": "0.15.5",
  "private": true,
  "productName": "Agent Infinite",
  "description": "Windows desktop control plane for Claude Code, Codex, Pi, and OpenCode agent teams.",
  "author": "Agent Infinite",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.node.json --pretty false && tsc --noEmit -p tsconfig.web.json --pretty false && electron-vite build",
    "dist:win": "electron-builder --win nsis --x64",
    "test": "vitest run",
    "test:e2e": "playwright test -c playwright.config.ts",
    "lint": "eslint src e2e electron.vite.config.ts vitest.config.ts playwright.config.ts && tsc --noEmit -p e2e/tsconfig.json --pretty false"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "@xyflow/react": "12.11.2",
    "lucide-react": "1.24.0",
    "pixi.js": "8.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "com.agentinfinite.desktop",
    "productName": "Agent Infinite",
    "artifactName": "Agent-Infinite-Setup-${version}-${arch}.${ext}",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/agent-infinite-backend.exe",
        "to": "agent-infinite-backend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agent Infinite",
      "uninstallDisplayName": "Agent Infinite"
    }
  }
}
